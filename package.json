{
  "name": "umbrella-budget",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.server.json && esbuild src/frontend/main.ts --bundle --outfile=public/bundle.js --minify --platform=browser",
    "dev": "concurrently \"tsc -p tsconfig.server.json -w\" \"esbuild src/frontend/main.ts --bundle --outfile=public/bundle.js --watch --platform=browser\" \"nodemon dist/server.js\"",
    "start": "node dist/server.js",
    "format": "prettier --write \"src/**/*.ts\" \"public/*.css\" \"public/*.html\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "express": "^4.18.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.8",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.3.2"
  }
}
